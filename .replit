modules = ["php-8.2", "nodejs-20", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
MAIL_MAILER = "smtp"
MAIL_SCHEME = "smtps"
MAIL_HOST = "mail.dreamstechnology.in"
MAIL_PORT = "465"
MAIL_USERNAME = "support@dreamstechnology.in"
MAIL_FROM_ADDRESS = "support@dreamstechnology.in"
MAIL_FROM_NAME = "Dreams Technology CRM"
APP_NAME = "Hotel CRM"
SESSION_LIFETIME = "10080"
QUEUE_CONNECTION = "redis"
CACHE_STORE = "redis"
SESSION_DRIVER = "redis"

[userenv.development]
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://0.0.0.0:5000"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
DB_PASSWORD = "password"

[userenv.production]
APP_ENV = "production"
APP_DEBUG = "false"
APP_URL = "https://resort.dreamstechnology.in"
APP_KEY = "base64:NZ5Yz5LDAMcq/1gdsSxblXQDbl0GWqTmdR053zUSbFE="
DB_CONNECTION = "pgsql"
CRON_SECRET = "11073c9e78260af3a72e8833bcb4683fc324e49e13ecc50b"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 6379
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "scripts/start.sh"]
build = ["bash", "-c", "composer install --no-dev --optimize-autoloader && php artisan config:clear && php artisan cache:clear && php artisan optimize && php artisan app:safe-migrate"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
