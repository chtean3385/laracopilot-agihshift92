modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
MAIL_MAILER = "smtp"
MAIL_SCHEME = "smtps"
MAIL_HOST = "mail.dreamstechnology.in"
MAIL_PORT = "465"
MAIL_USERNAME = "support@dreamstechnology.in"
MAIL_FROM_ADDRESS = "support@dreamstechnology.in"
MAIL_FROM_NAME = "Hotel CRM"

[userenv.development]
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://0.0.0.0:5000"

[userenv.production]
APP_ENV = "production"
APP_DEBUG = "false"
APP_URL = "https://resort.dreamstechnology.in"
DB_CONNECTION = "pgsql"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "php artisan config:cache && php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=${PORT:-5000}"]
publicDir = "public"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
